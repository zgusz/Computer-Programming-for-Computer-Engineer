#include <stdio.h>

int *KnapsackGreedy(int *w, int *v, int n, int wx){
    static int x[100];
    float r[100];
    int used[100];
    for(int i = 0; i < n; i++){
        x[i] = 0;
        r[i] = (float)v[i] / w[i];
        used[i] = 0;
    }
    int capacity = wx;
    for(int k = 0; k < n; k++){
        int maxIndex = -1;
        float maxRatio = -1;

        for(int i = 0; i < n; i++){
            if(!used[i] && r[i] > maxRatio){
                maxRatio = r[i];
                maxIndex = i;
            }
        }
        used[maxIndex] = 1;
        if(w[maxIndex] <= capacity){
            x[maxIndex] = 1;
            capacity -= w[maxIndex];
        }
    }

    return x;
};

int main() {
    int n = 5, wx = 11;
    int w[5] = {1, 2, 5, 6, 7};
    int v[5] = {1, 6, 18, 22, 28};
    int *x = KnapsackGreedy(w, v, n, wx);
    for(int i = 0; i < n; i++){
        printf("%d ", x[i]);
    };
    return 0;
}
