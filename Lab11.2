#include <stdio.h>

void merge(int *u, int m, int *v, int n, int *t) {
    int i = 0;
    int j = 0;
    for (int k = 0; k < (m + n); k++) {
        if (i >= m) {
            t[k] = v[j];
            j = j + 1;
        } else if (j >= n) {
            t[k] = u[i];
            i = i + 1;
        } else if (u[i] < v[j]) {
            t[k] = u[i];
            i = i + 1;
        } else {
            t[k] = v[j];
            j = j + 1;
        }
    }
}

void mergesort(int t[], int n) {
    if (n > 1) {
        int mid = n / 2;
        int size_u = mid;
        int size_v = n - mid;

        int u[size_u]; 
        int v[size_v];

        for (int i = 0; i < size_u; i++) {
            u[i] = t[i];
        }
        for (int i = 0; i < size_v; i++) {
            v[i] = t[mid + i];
        }
        mergesort(u, size_u);
        mergesort(v, size_v);
        merge(u, size_u, v, size_v, t);
    }
}

int main() {
    int data[7] = {4, 6, 1, 2, 5, 1, 8};
    int n = 7;
    mergesort(data, n);
    for (int i = 0; i < n; i++) {
        printf("%d ", data[i]);
    }
    return 0;
}
