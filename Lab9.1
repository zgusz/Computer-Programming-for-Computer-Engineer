#include <stdio.h>
#include <string.h>
#include <stdlib.h>

struct studentNode {
    char name[ 20 ];
    int age;
    char sex ;
    float gpa ;
    struct studentNode *next ;
};

class LinkedList {
    protected :
        struct studentNode *start;
        struct studentNode **now;
    public:
        LinkedList();
        ~LinkedList();
        void InsNode(char n[], int a, char s, float g ) ;
        void DelNode();
        void GoNext();
        void GoFirst();
        void GoLast();
        void ShowAll();
        int FindNode(char n[]) ;
        struct studentNode *NowNode();
        void EditNode( char n[], int a, char s, float g);
};

LinkedList::LinkedList() {
    start = NULL;
    now = &start;
}

LinkedList::~LinkedList() {
    struct studentNode *temp;
    while (start != NULL) {
        temp = start;
        start = start->next;
        delete temp;
    }
}

void LinkedList::InsNode(char n[], int a, char s, float g) {
    struct studentNode *newNode = new struct studentNode;
    strcpy(newNode->name, n);
    newNode->age = a;
    newNode->sex = s;
    newNode->gpa = g;
    newNode->next = *now;
    *now = newNode;
}

void LinkedList::DelNode() {
    if (*now == NULL) return;
    struct studentNode *temp = *now;
    *now = (*now)->next;
    delete temp;
}

void LinkedList::ShowAll() {
    struct studentNode *temp = start;
    printf("\n--- Student List ---\n");
    while (temp != NULL) {
        printf("Name: %-15s | Age: %d | Sex: %c | GPA: %.2f\n", temp->name, temp->age, temp->sex, temp->gpa);
        temp = temp->next;
    }
    printf("--------------------\n");
}

int LinkedList::FindNode(char n[]) {
    GoFirst();
    while (*now != NULL) {
        if (strcmp((*now)->name, n) == 0) return 1;
        GoNext();
    }
    return 0;
}

void LinkedList::GoFirst() {
    now = &start;
}

void LinkedList::GoNext() {
    if (*now != NULL) now = &((*now)->next);
}

struct studentNode* LinkedList::NowNode() {
    return *now;
}

void LinkedList::EditNode(char n[], int a, char s, float g) {
    if (*now != NULL) {
        strcpy((*now)->name, n);
        (*now)->age = a;
        (*now)->sex = s;
        (*now)->gpa = g;
    }
}

void AddData(LinkedList *ll) {
    char n[20], s;
    int a;
    float g;
    printf("Enter Name: "); scanf("%s", n);
    printf("Enter Age: "); scanf("%d", &a);
    printf("Enter Sex (M/F): "); scanf(" %c", &s);
    printf("Enter GPA: "); scanf("%f", &g);
    ll->GoFirst();
    ll->InsNode(n, a, s, g);
}

void EditData(LinkedList *ll) {
    char n[20], s;
    int a;
    float g;
    printf("Enter name to edit: "); scanf("%s", n);
    if (ll->FindNode(n)) {
        printf("Enter New Age: "); scanf("%d", &a);
        printf("Enter New Sex: "); scanf(" %c", &s);
        printf("Enter New GPA: "); scanf("%f", &g);
        ll->EditNode(n, a, s, g);
        printf("Update successful.\n");
    } else {
        printf("Student not found.\n");
    }
}

void FindData(LinkedList *ll) {
    char n[20];
    printf("Enter name to search: "); scanf("%s", n);
    if (ll->FindNode(n)) {
        struct studentNode *node = ll->NowNode();
        printf("Found: %s, Age: %d, Sex: %c, GPA: %.2f\n", node->name, node->age, node->sex, node->gpa);
    } else {
        printf("Not found.\n");
    }
}

void readfile(LinkedList *ll) {
    FILE *fp = fopen("students.txt", "r");
    if (fp == NULL) return;
    char n[20], s;
    int a;
    float g;
    while (fscanf(fp, "%s %d %c %f", n, &a, &s, &g) != EOF) {
        ll->InsNode(n, a, s, g);
    }
    fclose(fp);
}

void writefile(LinkedList *ll) {
    FILE *fp = fopen("students.txt", "w");
    if (fp == NULL) return;
    ll->GoFirst();
    while (ll->NowNode() != NULL) {
        struct studentNode *node = ll->NowNode();
        fprintf(fp, "%s %d %c %f\n", node->name, node->age, node->sex, node->gpa);
        ll->GoNext();
    }
    fclose(fp);
}

int main() {
    LinkedList listA;
    int menu;
    readfile(&listA);
    
    do {
        printf("\nMenu - (1) Add (2) Edit (3) Delete (4) Find (5) Show (0) Exit: ");
        if (scanf("%d", &menu) != 1) break;

        switch(menu) {
            case 1: AddData(&listA); break;
            case 2: EditData(&listA); break;
            case 3: 
                char nameDel[20];
                printf("Enter name to delete: "); scanf("%s", nameDel);
                if (listA.FindNode(nameDel)) listA.DelNode();
                break;
            case 4: FindData(&listA); break;
            case 5: listA.ShowAll(); break;
        }
    } while(menu != 0);

    writefile(&listA);
    return 0;
}
